    }
    {duration} {($$playerLevel / 3.0) + 1}
    {shortcut} {
      {cmd}    {}
      {action} {}
    }
  }
  {water breathe} {
    {messages} {
      {apply}  {^You feel that you can breathe in water.$}
      {warn}   {^Your ability to breathe water is leaving you.$}
      {remove} {^The ability to breathe water left you.$}
      {score}  {^You can breathe in water.$}
