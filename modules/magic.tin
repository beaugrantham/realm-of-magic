};

/*
 * Set up actions and aliases for each of the affects.
 */
#FOREACH {*affects[%*]} {affect} {
  #LINE SUBSTITUTE variables {
    #IF {"@isEmpty{$affects[$affect][messages][apply]; true}" != "true"} {
      #ACTION {$affects[$affect][messages][apply]} {succeedSpell {%0} {$affect}};
    };
    #IF {"@isEmpty{$affects[$affect][messages][warn]; true}" != "true"} {
      #ACTION {$affects[$affect][messages][warn]} {warnSpell {%0} {$affect}};
    };
    #IF {"@isEmpty{$affects[$affect][messages][remove]; true}" != "true"} {
      #ACTION {$affects[$affect][messages][remove]} {endSpell {%0} {$affect}};
    };
    #IF {"@isEmpty{$affects[$affect][messages][score]; true}" != "true"} {
      #ACTION {$affects[$affect][messages][score]} {setActive {%0} {$affect}};
    };

    #IF {"@isEmpty{$affects[$affect][shortcut][cmd]; true}" != "true"} {
      #ALIAS {$affects[$affect][shortcut][cmd]} {$affects[$affect][shortcut][action]};
    };
  };
};
