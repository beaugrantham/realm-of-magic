    }
    {duration} {24}
    {shortcut} {
      {cmd}    {ci}
      {action} {castTarget {invisibility} {%1}}
    }
  }
  {natural protection} {
    {messages} {
      {apply}  {}
      {warn}   {}
      {remove} {^You no longer feel a tingle in your skin.$}
      {score}  {^The tingle of nature's protection races through your body.$}
    }
    {duration} {6}
    {shortcut} {
      {cmd}    {}
      {action} {}
    }
  }
  {night vision} {
    {messages} {
      {apply}  {}
      {warn}   {^Your infravision begins to fade.$}
      {remove} {^You can no longer see in the dark.$}
      {score}  {^No creature can hide from you in the dark.$}
    }
    {duration} {$$playerLevel + 5}
    {shortcut} {
      {cmd}    {cnv}
      {action} {cast 'night vision' self}
    }
  }
  {peace} {
    {messages} {
      {apply}  {^A peaceful feeling surrounds you.$}
      {warn}   {^The peace around you is about to fade.$}
      {remove} {^The peace around you is gone.$}
      {score}  {^You're spreading an aura of peace.$}
    }
    {duration} {$$playerLevel / 4.0}
    {shortcut} {
      {cmd}    {cpeace}
      {action} {cast 'peace' self}
    }
  }
  {sanctuary} {
    {messages} {
      {apply}  {^You start glowing.$}
      {warn}   {^The aura around your body flickers slightly.$}
      {remove} {^The aura around your body fades.$}
      {score}  {^You are protected by Sanctuary.$}
    }
    {duration} {3}
    {shortcut} {
      {cmd}    {csanc}
      {action} {castTarget {sanctuary} {%1}}
    }
  }
  {sense life} {
    {messages} {
      {apply}  {^You feel your awareness improve.$}
      {warn}   {}
      {remove} {^You feel less aware of your surroundings.$}
      {score}  {^You can feel the presence of living beings around you.$}
    }
    {duration} {$$playerLevel * 5}
    {shortcut} {
      {cmd}    {csl}
      {action} {cast 'sense life' self}
    }
  }
  {stone skin} {
    {messages} {
      {apply}  {^You feel your skin turning into stone. You are protected.$}
      {warn}   {}
      {remove} {^You feel your skin again.$}
      {score}  {^You have skin as tough as stone.$}
